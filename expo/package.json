    "@vonovak/react-native-theme-control": "^7.0.2",
    "expo": "^56.0.0",
    "expo-font": "~56.0.7",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "nativewind": "^4.1.0",
    "react": "19.2.3",
